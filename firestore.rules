rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role (professional|beneficiary|admin), createdAt
    //
    // Collection: sessions
    // Fields: professionalId, beneficiaryId, activity, date, startTime, endTime, durationMinutes, createdAt
    //
    // Collection: workshops
    // Fields: title, type, professionalId, beneficiaryIds (array), date, createdAt
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isProfessional() {
      return isAuthenticated() && getUserData().role == 'professional';
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || 
         (request.auth.token.email == "daniacontrerasr@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             data.role in ['professional', 'beneficiary', 'admin'] &&
             data.name is string && data.name.size() < 100;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['professionalId', 'beneficiaryId', 'activity', 'date', 'startTime', 'endTime']) &&
             data.professionalId == request.auth.uid &&
             data.activity is string && data.activity.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.professionalId || request.auth.uid == resource.data.beneficiaryId || isAdmin());
      allow create: if isProfessional() && isValidSession(request.resource.data);
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.professionalId || isAdmin());
    }

    match /workshops/{workshopId} {
      allow read: if isAuthenticated();
      allow create: if isProfessional() || isAdmin();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.professionalId || isAdmin());
    }
  }
}
